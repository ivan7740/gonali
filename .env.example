# =============================================================================
# UNII — environment variable template
# Copy to .env and fill in real values. .env is git-ignored.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=unii
POSTGRES_USER=unii
POSTGRES_PASSWORD=changeme_in_real_env

# Connection string used by sqlx in the unii-server container and locally.
# Inside docker compose network the host is "postgres"; from your host machine
# it becomes "localhost". Use the appropriate one when running migrations.
DATABASE_URL=postgres://unii:changeme_in_real_env@postgres:5432/unii

# --- JWT ----------------------------------------------------------------------
# Generate with:  openssl rand -hex 64
JWT_SECRET=replace_me_with_a_64_byte_hex_string

# --- Server -------------------------------------------------------------------
SERVER_PORT=8080
RUST_LOG=info,unii_server=debug,sqlx=warn

# --- 高德 (for backend proxy of route / POI APIs in W4+) ---------------------
# Get from https://lbs.amap.com/  →  Web服务 Key
AMAP_WEB_KEY=

# --- OSRM (optional self-hosted; W4+) -----------------------------------------
OSRM_BASE_URL=http://router.project-osrm.org

# --- Object storage (W5 media uploads; W1 not used) --------------------------
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=unii-media
